---
layout: null
sitemap: false
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% assign production_url = site.data.settings.production_url | default: site.url %}
{% assign sitemap_items = site.site_pages | concat: site.articles | concat: site.product_series | sort: "url" %}
{% for item in sitemap_items %}
  {% unless item.published == false or item.sitemap == false %}
  {% assign item_lastmod = item.last_modified_at | default: item.date | default: site.time %}
  <url>
    <loc>{{ item.url | prepend: production_url | xml_escape }}</loc>
    <lastmod>{{ item_lastmod | date_to_xmlschema }}</lastmod>
  </url>
  {% endunless %}
{% endfor %}
</urlset>
